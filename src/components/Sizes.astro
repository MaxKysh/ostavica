---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { useTranslations } from '../i18n/ui.js';
import scale1 from '../images/viz-scale-1_5m.jpg';
import scale2 from '../images/viz-scale-2m.jpg';
import scale3 from '../images/viz-scale-3_3m.jpg';

const { lang } = Astro.props;
const t = useTranslations(lang);
const cards = t('sizes.cards');
const scales = [scale1, scale2, scale3];

const altFor = (size) =>
  ({
    ru: `Схема ячейки ${size} с примером заполнения`,
    sr: `Šema boksa ${size} sa primerom popunjenosti`,
    en: `Scale diagram of a ${size} storage unit with example contents`,
  })[lang];
---
<section id="sizes" class="section sizes">
  <div class="container">
    <div class="section-head reveal">
      <span class="kicker">{t('sizes.kicker')}</span>
      <h2>{t('sizes.h2')}</h2>
    </div>

    <ul class="sizes-grid">
      {cards.map((card, i) => (
        <li
          class:list={['size-card card reveal', { popular: card.popular }]}
          style={`transition-delay:${i * 80}ms`}
        >
          {card.popular && <span class="size-badge"><Icon name="check" size={14} />{t('sizes.badge')}</span>}
          <div class="size-media">
            <Image
              src={scales[i]}
              alt={altFor(card.size)}
              widths={[240, 360, 480]}
              sizes="(min-width: 760px) 320px, 90vw"
              format="webp"
              quality={75}
              loading="lazy"
              class="size-img"
            />
          </div>
          <div class="size-body">
            <div class="size-name">{card.size}</div>
            <p class="size-desc">{card.desc}</p>
            <div class="size-price">
              {card.price}<span class="size-per">{t('sizes.per')}</span>
            </div>
            <button
              type="button"
              class:list={['btn', 'btn-block', card.popular ? 'btn-primary' : 'btn-soft']}
              data-choose-size={i}
            >{t('sizes.cta')}</button>
          </div>
        </li>
      ))}
    </ul>

    <p class="sizes-note reveal">{t('sizes.note')}</p>
  </div>
</section>

<style>
  /* Mobile: swipeable carousel with the neighbouring cards peeking on both sides */
  .sizes-grid {
    list-style: none;
    margin: 0;
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    /* bleed to the viewport edges so cards can peek past the container padding */
    margin-inline: calc(-1 * var(--pad));
    padding-inline: var(--pad);
    scroll-padding-inline: var(--pad);
  }
  .sizes-grid::-webkit-scrollbar {
    display: none;
  }
  .size-card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    flex: 0 0 80%;
    scroll-snap-align: center;
  }
  .size-card.popular {
    background: var(--green-soft);
  }
  .size-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--green);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 5px 10px;
    border-radius: 999px;
  }
  .size-media {
    background: #fff;
    aspect-ratio: 4 / 3;
  }
  .size-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
  }
  .size-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .size-name {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.5rem;
  }
  .size-desc {
    color: var(--muted);
    font-size: 0.92rem;
    margin: 6px 0 14px;
    min-height: 2.8em;
  }
  .size-price {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.9rem;
    margin-bottom: 16px;
  }
  .size-per {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--muted);
  }
  .size-body .btn {
    margin-top: auto;
  }
  .sizes-note {
    text-align: center;
    color: var(--muted);
    font-size: 0.92rem;
    margin-top: 22px;
    max-width: 60ch;
    margin-inline: auto;
  }

  @media (min-width: 760px) {
    /* Desktop: back to a static 3-column grid (no carousel) */
    .sizes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      overflow: visible;
      margin-inline: 0;
      padding-inline: 0;
      align-items: start;
    }
    .size-card {
      flex: initial;
    }
  }
</style>

<script>
  // On mobile, start the carousel centred on the popular card so both neighbours peek.
  const grid = document.querySelector('.sizes-grid');
  const popular = grid?.querySelector('.size-card.popular');
  if (grid && popular && window.matchMedia('(max-width: 759px)').matches) {
    requestAnimationFrame(() => {
      const g = grid.getBoundingClientRect();
      const p = popular.getBoundingClientRect();
      grid.scrollLeft += p.left - g.left - (grid.clientWidth - popular.clientWidth) / 2;
    });
  }

  // "Choose" → scroll to form and preselect the size in the dropdown.
  document.querySelectorAll('[data-choose-size]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = btn.getAttribute('data-choose-size');
      const select = document.getElementById('field-size');
      const form = document.getElementById('reserve');
      if (select) select.value = index;
      if (form) {
        form.scrollIntoView({ behavior: 'smooth', block: 'start' });
        window.setTimeout(() => select && select.focus({ preventScroll: true }), 500);
      }
    });
  });
</script>
