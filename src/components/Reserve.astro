---
import Icon from './Icon.astro';
import { useTranslations } from '../i18n/ui.js';

const { lang } = Astro.props;
const t = useTranslations(lang);
const f = t('reserve.form');

const phone = t('footer.phone');
const tel = `tel:${phone.replace(/\s+/g, '')}`;

// Localized status messages (not part of the content dictionary).
const msg = {
  ru: {
    success: 'Спасибо! Заявка получена — мы свяжемся с вами в ближайшее время.',
    successMail: 'Спасибо! Открылось письмо с заявкой — отправьте его, и мы свяжемся с вами.',
    error: 'Не удалось отправить. Попробуйте ещё раз или напишите нам напрямую.',
    sending: 'Отправляем…',
    invalidName: 'Введите имя',
    invalidContact: 'Оставьте контакт: телефон, @ник или email',
  },
  sr: {
    success: 'Hvala! Upit je primljen — javićemo vam se uskoro.',
    successMail: 'Hvala! Otvorio se mejl sa upitom — pošaljite ga i javićemo vam se.',
    error: 'Slanje nije uspelo. Pokušajte ponovo ili nam pišite direktno.',
    sending: 'Šaljemo…',
    invalidName: 'Unesite ime',
    invalidContact: 'Ostavite kontakt: telefon, @nadimak ili email',
  },
  en: {
    success: 'Thanks! Your request was received — we’ll be in touch shortly.',
    successMail: 'Thanks! An email with your request opened — send it and we’ll be in touch.',
    error: 'Couldn’t send. Please try again or message us directly.',
    sending: 'Sending…',
    invalidName: 'Enter your name',
    invalidContact: 'Leave a contact: phone, @handle or email',
  },
}[lang];

// Where leads go for now (no backend yet): opens the visitor's mail client
// prefilled to this address. Swap to PUBLIC_LEAD_ENDPOINT (Formspree/webhook)
// for silent server-side delivery later.
const LEAD_EMAIL = 'maxkysh@gmail.com';
---
<section id="reserve" class="section reserve">
  <div class="container reserve-grid">
    <div class="reserve-intro reveal">
      <h2>{t('reserve.h2')}</h2>
      <p class="reserve-sub">{t('reserve.sub')}</p>
      <p class="reserve-call">
        {f.callNote} <a href={tel}>{phone}</a>
      </p>
    </div>

    <div class="reserve-card card reveal">
      <form id="reserve-form" class="reserve-form" novalidate>
        <div class="field">
          <label for="field-name">{f.name}</label>
          <input
            id="field-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            placeholder={f.namePlaceholder}
          />
        </div>

        <div class="field">
          <label for="field-what">{f.what}</label>
          <div class="select-wrap">
            <select id="field-what" name="what" required>
              <option value="" disabled selected>{f.what}</option>
              {f.whatOptions.map((opt) => <option value={opt}>{opt}</option>)}
            </select>
            <span class="select-chevron"><Icon name="chevronDown" size={18} /></span>
          </div>
        </div>

        <div class="field">
          <label for="field-size">{f.size}</label>
          <div class="select-wrap">
            <select id="field-size" name="size" required>
              <option value="" disabled selected>{f.size}</option>
              {f.sizeOptions.map((opt, i) => <option value={String(i)}>{opt}</option>)}
            </select>
            <span class="select-chevron"><Icon name="chevronDown" size={18} /></span>
          </div>
        </div>

        <div class="field">
          <label for="field-contact">{f.contact}</label>
          <input id="field-contact" name="contact" type="text" required placeholder={f.contact} />
        </div>

        <!-- Hidden tracking fields (populated from the URL at runtime) -->
        <input type="hidden" name="locale" value={lang} />
        <input type="hidden" name="utm_source" />
        <input type="hidden" name="utm_medium" />
        <input type="hidden" name="utm_campaign" />
        <input type="hidden" name="utm_term" />
        <input type="hidden" name="utm_content" />
        <input type="hidden" name="referrer" />
        <!-- Honeypot: bots fill this, humans don't. `_gotcha` is Formspree's own honeypot name. -->
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="honeypot" aria-hidden="true" />

        <button type="submit" class="btn btn-primary btn-block reserve-submit">
          {f.submit}<Icon name="arrowRight" size={18} />
        </button>
        <p class="reserve-micro">{f.micro}</p>
        <p id="reserve-status" class="reserve-status" role="status" aria-live="polite" hidden></p>
      </form>
    </div>
  </div>
</section>

<style>
  .reserve {
    background: var(--green-deep);
  }
  .reserve-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(24px, 5vw, 44px);
    align-items: start;
  }
  .reserve-intro h2 {
    font-size: clamp(1.6rem, 5vw, 2.3rem);
    margin-bottom: 14px;
    color: #fff;
  }
  .reserve-sub {
    color: #dcebd0;
    font-size: 1.05rem;
    max-width: 40ch;
  }
  /* Secondary contact — kept low-key so the form stays the primary action */
  .reserve-call {
    margin-top: 18px;
    font-size: 0.92rem;
    color: #bcd3ab;
  }
  .reserve-call a {
    color: #fff;
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    padding-bottom: 1px;
  }
  .reserve-call a:hover {
    border-bottom-color: #fff;
  }
  .reserve-card {
    padding: clamp(20px, 4vw, 30px);
  }
  .field {
    margin-bottom: 16px;
  }
  .field label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 7px;
  }
  input[type='text'],
  select {
    width: 100%;
    padding: 14px 14px;
    border: 0;
    border-radius: var(--radius-sm);
    background: var(--surface-2);
    transition: background-color 0.18s ease;
  }
  input[type='text']::placeholder {
    color: #7d8a7f;
  }
  input[type='text']:focus,
  select:focus {
    background: #dde6d4;
  }
  .select-wrap {
    position: relative;
  }
  select {
    appearance: none;
    -webkit-appearance: none;
    padding-right: 40px;
    cursor: pointer;
  }
  .select-chevron {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    pointer-events: none;
  }
  .reserve-submit {
    margin-top: 6px;
  }
  .reserve-micro {
    text-align: center;
    color: var(--muted);
    font-size: 0.82rem;
    margin-top: 12px;
  }
  .reserve-status {
    margin-top: 14px;
    padding: 12px 14px;
    border-radius: var(--radius-sm);
    font-size: 0.92rem;
  }
  .reserve-status.ok {
    background: rgba(111, 190, 63, 0.14);
    color: var(--green-dark);
  }
  .reserve-status.err {
    background: #fdecea;
    color: #b3261e;
  }
  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  @media (min-width: 820px) {
    .reserve-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: 56px;
    }
    .reserve-intro {
      position: sticky;
      top: 96px;
    }
  }
</style>

<script>
  const form = document.getElementById('reserve-form');
  const statusEl = document.getElementById('reserve-status');

  // Localized status strings + lead email injected from the frontmatter.
  const MESSAGES = JSON.parse(document.getElementById('reserve-form').dataset.messages || '{}');
  const LEAD_EMAIL = document.getElementById('reserve-form').dataset.leadEmail || '';

  // Pull UTM params + referrer from the URL into the hidden fields (channel attribution).
  const params = new URLSearchParams(window.location.search);
  ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'].forEach((key) => {
    const input = form?.elements.namedItem(key);
    if (input && params.get(key)) input.value = params.get(key);
  });
  const ref = form?.elements.namedItem('referrer');
  if (ref) ref.value = document.referrer || '';

  // PUBLIC_LEAD_ENDPOINT is inlined at build time (Formspree URL or your own webhook).
  const ENDPOINT = import.meta.env.PUBLIC_LEAD_ENDPOINT || '';

  function setStatus(text, kind) {
    if (!statusEl) return;
    statusEl.textContent = text;
    statusEl.hidden = false;
    statusEl.classList.remove('ok', 'err');
    if (kind) statusEl.classList.add(kind);
  }

  // Custom validation (beyond the HTML `required`): reject whitespace-only /
  // too-short name and contact, with a localized message on the field itself.
  function validate() {
    const nameEl = form.elements.namedItem('name');
    const contactEl = form.elements.namedItem('contact');
    nameEl.setCustomValidity(nameEl.value.trim().length < 2 ? MESSAGES.invalidName : '');
    contactEl.setCustomValidity(contactEl.value.trim().length < 3 ? MESSAGES.invalidContact : '');
  }
  ['name', 'contact'].forEach((n) => {
    const el = form?.elements.namedItem(n);
    el?.addEventListener('input', () => el.setCustomValidity(''));
  });

  function buildMailto(data) {
    const subject = `Ostavica — заявка: ${data.name || '—'}`;
    const lines = [
      `Имя: ${data.name || '—'}`,
      `Что хранить: ${data.what || '—'}`,
      `Размер: ${data.size || '—'}`,
      `Контакт: ${data.contact || '—'}`,
      `Язык страницы: ${data.locale || '—'}`,
    ];
    ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'referrer'].forEach((k) => {
      if (data[k]) lines.push(`${k}: ${data[k]}`);
    });
    return `mailto:${LEAD_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(lines.join('\n'))}`;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    validate();
    if (!form.reportValidity()) return;
    // Honeypot tripped → silently pretend success.
    if (form.elements.namedItem('_gotcha')?.value) {
      setStatus(MESSAGES.success, 'ok');
      form.reset();
      return;
    }

    // Build a readable payload (use the visible option text for the selects).
    const data = Object.fromEntries(new FormData(form).entries());
    const sizeSelect = form.elements.namedItem('size');
    if (sizeSelect && sizeSelect.selectedIndex >= 0) {
      data.size = sizeSelect.options[sizeSelect.selectedIndex].text;
    }
    delete data._gotcha;

    const submitBtn = form.querySelector('button[type="submit"]');
    const originalLabel = submitBtn?.innerHTML;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = MESSAGES.sending;
    }

    let successMsg = MESSAGES.success;
    try {
      if (ENDPOINT) {
        // Preferred path: silent server-side delivery (Formspree/webhook).
        const payload = { ...data, _subject: `Ostavica — заявка: ${data.name || '—'}` };
        // If the contact is an email, let Formspree set it as reply-to.
        const contact = (data.contact || '').trim();
        if (/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(contact)) payload.email = contact;
        const res = await fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(`Request failed: ${res.status}`);
      } else {
        // No backend configured → open the visitor's mail client, prefilled to LEAD_EMAIL.
        const mailto = buildMailto(data);
        console.log('[Ostavica] Lead → opening mail client:', mailto);
        window.location.href = mailto;
        successMsg = MESSAGES.successMail;
      }
      setStatus(successMsg, 'ok');
      form.reset();
    } catch (err) {
      console.error('[Ostavica] Lead submit failed:', err);
      setStatus(MESSAGES.error, 'err');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalLabel;
      }
    }
  });
</script>

<script is:inline define:vars={{ messages: msg, leadEmail: LEAD_EMAIL }}>
  // Hand the localized strings + lead email to the module script via data attributes.
  const rf = document.getElementById('reserve-form');
  rf.dataset.messages = JSON.stringify(messages);
  rf.dataset.leadEmail = leadEmail;
</script>
