---
import { Image } from 'astro:assets';
import { useTranslations } from '../i18n/ui.js';
import hall from '../images/space-hall-02.jpg';
import heated from '../images/feature-heated.jpg';
import facade from '../images/exterior-facade.jpg';

const { lang } = Astro.props;
const t = useTranslations(lang);

// Each photo is used once across the whole page (no duplicates).
const gallery = [
  {
    src: hall,
    alt: {
      ru: 'Просторный зал склада с рядами белых ячеек и дневным светом',
      sr: 'Prostrana sala skladišta sa redovima belih boksova i dnevnim svetlom',
      en: 'Spacious storage hall with rows of white units and daylight',
    }[lang],
  },
  {
    src: heated,
    alt: {
      ru: 'Отапливаемое помещение склада с термометром на стене',
      sr: 'Grejani prostor skladišta sa termometrom na zidu',
      en: 'Heated storage room with a thermometer on the wall',
    }[lang],
  },
  {
    src: facade,
    alt: {
      ru: 'Закрытый внутренний двор и фасад с зелёным знаком Ostavica',
      sr: 'Zatvoreno dvorište i fasada sa zelenim znakom Ostavica',
      en: 'Gated courtyard and façade with the green Ostavica sign',
    }[lang],
  },
];
---
<section id="space" class="section space">
  <div class="container">
    <div class="section-head reveal">
      <span class="kicker">{t('space.kicker')}</span>
      <h2>{t('space.h2')}</h2>
    </div>

    <div class="gallery">
      {gallery.map((g, i) => (
        <figure class="gallery-item reveal" style={`transition-delay:${i * 70}ms`}>
          <Image
            src={g.src}
            alt={g.alt}
            widths={[400, 600, 800]}
            sizes="(min-width: 760px) 340px, 92vw"
            format="webp"
            quality={75}
            loading="lazy"
            class="gallery-img"
          />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .gallery-item {
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }
  .gallery-img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  @media (min-width: 640px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 880px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
