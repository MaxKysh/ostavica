---
import { Image } from 'astro:assets';
import { useTranslations } from '../i18n/ui.js';
import founder from '../images/person.jpg';

const { lang } = Astro.props;
const t = useTranslations(lang);

const founderAlt = {
  ru: 'Основатель Ostavica Илья с ключами от ячеек',
  sr: 'Osnivač Ostavice Ilja sa ključevima od boksova',
  en: 'Ilya, founder of Ostavica, holding the unit keys',
}[lang];

const mapTitle = {
  ru: 'Карта: расположение склада Ostavica в Нови-Саде',
  sr: 'Mapa: lokacija skladišta Ostavica u Novom Sadu',
  en: 'Map: Ostavica storage location in Novi Sad',
}[lang];

// Location resolved from the shared Google Maps link (Đorđa Rajkovića 15, Novi Sad).
const mapSrc = `https://www.google.com/maps?q=45.2638907,19.8490506&z=14&hl=${lang}&output=embed`;
---
<section id="about" class="section about">
  <div class="container">
    <div class="section-head reveal">
      <span class="kicker">{t('about.kicker')}</span>
      <h2>{t('about.sectionTitle')}</h2>
    </div>

    <div class="about-grid reveal">
      <div class="about-media">
        <Image
          src={founder}
          alt={founderAlt}
          widths={[240, 340, 460]}
          sizes="(min-width: 900px) 280px, (min-width: 560px) 45vw, 90vw"
          format="webp"
          quality={75}
          loading="lazy"
          class="about-img"
        />
      </div>

      <div class="about-copy">
        <h3>{t('about.h2')}</h3>
        <p class="about-text">{t('about.text')}</p>
      </div>

      <div class="about-map">
        <iframe
          class="about-map-frame"
          src={mapSrc}
          title={mapTitle}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vw, 28px);
  }
  .about-media {
    max-width: 320px;
    align-self: start;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius);
  }
  .about-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .about-copy h3 {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: clamp(1.3rem, 2.4vw, 1.6rem);
    margin-bottom: 14px;
  }
  .about-text {
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.62;
  }
  .about-map-frame {
    display: block;
    width: 100%;
    min-height: 280px;
    height: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  /* Tablet: photo + text side by side, map full width below */
  @media (min-width: 560px) and (max-width: 899px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
    }
    .about-map {
      grid-column: 1 / -1;
    }
    .about-map-frame {
      min-height: 320px;
    }
  }

  /* Desktop: four columns — photo · text · map (spans 2) */
  @media (min-width: 900px) {
    .about-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: clamp(20px, 2vw, 28px);
      align-items: stretch;
    }
    .about-media {
      max-width: none;
    }
    .about-copy {
      align-self: center;
    }
    .about-map {
      grid-column: 3 / 5;
    }
    .about-map-frame {
      min-height: 0; /* fill the row height set by the photo */
    }
  }
</style>
