---
import '../styles/global.css';
import { languages, localizedPath, useTranslations } from '../i18n/ui.js';
import CookieConsent from '../components/CookieConsent.astro';

const { lang } = Astro.props;
const t = useTranslations(lang);

const site = Astro.site ?? new URL('http://localhost:4321');
// hreflang alternates for every locale (+ x-default → ru).
const alternates = languages.map((l) => ({
  lang: l,
  href: new URL(localizedPath(l), site).href,
}));
const canonical = new URL(localizedPath(lang), site).href;

// Per-language social share image (1200×630).
const ogImage = new URL(`/og-${lang}.jpg`, site).href;

// Facebook/OG locale codes + alternates for the other languages.
const ogLocaleByLang = { ru: 'ru_RU', en: 'en_US', sr: 'sr_RS' };
const ogLocale = ogLocaleByLang[lang];
const ogLocaleAlternates = languages.filter((l) => l !== lang).map((l) => ogLocaleByLang[l]);

// LocalBusiness (SelfStorage) structured data — helps local/brand search.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SelfStorage',
  name: 'Ostavica',
  description: t('meta.description'),
  url: canonical,
  image: ogImage,
  logo: new URL('/favicon.svg', site).href,
  telephone: '+381677750165',
  priceRange: '€45–€75',
  currenciesAccepted: 'EUR',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Đorđa Rajkovića 15',
    addressLocality: 'Novi Sad',
    postalCode: '21000',
    addressCountry: 'RS',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 45.2638907, longitude: 19.8490506 },
  areaServed: { '@type': 'City', name: 'Novi Sad' },
  availableLanguage: ['ru', 'sr', 'en'],
  sameAs: languages.map((l) => new URL(localizedPath(l), site).href),
};

// Yandex.Metrika — loaded only in production builds so local/dev visits
// don't pollute the stats. Change the counter id here if it ever changes.
const YM_ID = 110343847;
const isProd = import.meta.env.PROD;
const ymScript = `(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};m[i].l=1*new Date();for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=${YM_ID}', 'ym');ym(${YM_ID}, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <!-- Mark JS as available before paint so reveal-on-scroll only hides content
         when JS can reveal it (no-JS users see everything). Also remember the
         current language so "/" can re-open it next time. -->
    <script is:inline define:vars={{ lang }}>
      document.documentElement.classList.add('js');
      try { localStorage.setItem('ostavica-lang', lang); } catch (e) {}
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{t('meta.title')}</title>
    <meta name="description" content={t('meta.description')} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#6fbe3f" />
    <meta name="apple-mobile-web-app-title" content="Ostavica" />
    <meta name="yandex-verification" content="364e649a8d4d6ddd" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ostavica" />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}
    <meta property="og:title" content={t('meta.title')} />
    <meta property="og:description" content={t('meta.description')} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t('meta.title')} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t('meta.title')} />
    <meta name="twitter:description" content={t('meta.description')} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    <CookieConsent lang={lang} />

    <!-- Consent-gated Yandex.Metrika: loads only after the visitor accepts.
         Returning visitors who already accepted get it loaded immediately. -->
    <script is:inline define:vars={{ ymEnabled: isProd, ymScript }}>
      (function () {
        var KEY = 'ostavica-cookie-consent';
        var banner = document.getElementById('cookie-banner');
        function loadMetrika() {
          if (!ymEnabled || window.__ymLoaded) return;
          window.__ymLoaded = 1;
          var s = document.createElement('script');
          s.type = 'text/javascript';
          s.text = ymScript;
          document.head.appendChild(s);
        }
        var consent = null;
        try {
          consent = localStorage.getItem(KEY);
        } catch (e) {}
        if (consent === 'granted') {
          loadMetrika();
        } else if (consent !== 'denied' && banner) {
          banner.hidden = false;
        }
        if (banner) {
          banner.addEventListener('click', function (e) {
            var btn = e.target.closest('[data-consent]');
            if (!btn) return;
            var accepted = btn.getAttribute('data-consent') === 'accept';
            try {
              localStorage.setItem(KEY, accepted ? 'granted' : 'denied');
            } catch (e) {}
            if (accepted) loadMetrika();
            banner.hidden = true;
          });
        }
      })();
    </script>

    <script>
      // ---- Sticky header background on scroll ----
      const header = document.getElementById('site-header');
      const onScroll = () => {
        if (!header) return;
        header.classList.toggle('is-scrolled', window.scrollY > 8);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // ---- Reveal-on-scroll (respects prefers-reduced-motion) ----
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealEls = document.querySelectorAll('.reveal');
      if (reduceMotion || !('IntersectionObserver' in window)) {
        revealEls.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.12 }
        );
        revealEls.forEach((el) => io.observe(el));
      }

      // ---- Language switcher: keep the current anchor across locales ----
      document.querySelectorAll('[data-lang-link]').forEach((link) => {
        link.addEventListener('click', () => {
          const hash = window.location.hash;
          if (hash) link.setAttribute('href', link.dataset.base + hash);
        });
      });
    </script>
  </body>
</html>
