---
import '../styles/global.css';
import { languages, localizedPath, useTranslations } from '../i18n/ui.js';

const { lang } = Astro.props;
const t = useTranslations(lang);

const site = Astro.site ?? new URL('http://localhost:4321');
// hreflang alternates for every locale (+ x-default → ru).
const alternates = languages.map((l) => ({
  lang: l,
  href: new URL(localizedPath(l), site).href,
}));
const canonical = new URL(localizedPath(lang), site).href;

// TODO: replace with a real, per-language OG image (1200×630) before launch.
const ogImage = new URL('/og-default.png', site).href;
---
<!doctype html>
<html lang={lang}>
  <head>
    <!-- Mark JS as available before paint so reveal-on-scroll only hides content
         when JS can reveal it (no-JS users see everything). -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{t('meta.title')}</title>
    <meta name="description" content={t('meta.description')} />
    <meta name="theme-color" content="#6fbe3f" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang} />
    <meta property="og:site_name" content="Ostavica" />
    <meta property="og:title" content={t('meta.title')} />
    <meta property="og:description" content={t('meta.description')} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <slot />

    <script>
      // ---- Sticky header background on scroll ----
      const header = document.getElementById('site-header');
      const onScroll = () => {
        if (!header) return;
        header.classList.toggle('is-scrolled', window.scrollY > 8);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // ---- Reveal-on-scroll (respects prefers-reduced-motion) ----
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealEls = document.querySelectorAll('.reveal');
      if (reduceMotion || !('IntersectionObserver' in window)) {
        revealEls.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.12 }
        );
        revealEls.forEach((el) => io.observe(el));
      }

      // ---- Language switcher: keep the current anchor across locales ----
      document.querySelectorAll('[data-lang-link]').forEach((link) => {
        link.addEventListener('click', () => {
          const hash = window.location.hash;
          if (hash) link.setAttribute('href', link.dataset.base + hash);
        });
      });
    </script>
  </body>
</html>
