---
import { Image } from 'astro:assets';
import logo from '../images/logo-mark.png';

/** Ostavica logo lockup — the original brand wordmark (transparent background). */
const { height = 30, class: className = '' } = Astro.props;
---
<span class={`brand ${className}`} aria-hidden="true">
  <Image
    src={logo}
    alt="Ostavica"
    widths={[180, 280, 400]}
    sizes="200px"
    format="webp"
    quality={90}
    loading="eager"
    class="brand-logo"
    style={`height:${height}px`}
  />
</span>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
  }
  .brand-logo {
    width: auto;
  }
</style>
