---
import { Image } from 'astro:assets';
import { useTranslations } from '../i18n/ui.js';
import tiresImg from '../images/fits-tires.jpg';
import boxesImg from '../images/fits-boxes.jpg';
import bikeImg from '../images/fits-bike-sport.jpg';
import movingImg from '../images/unit-open-tires-boxes-bike.jpg';

const { lang } = Astro.props;
const t = useTranslations(lang);
const items = t('fits.items');

// All four cards are real photos of an open unit, in one consistent style.
const photos = [tiresImg, boxesImg, bikeImg, movingImg];

const alts = {
  ru: [
    'Открытая ячейка с комплектом сезонных шин',
    'Открытая ячейка со штабелем картонных коробок',
    'Открытая ячейка с велосипедом и лыжами',
    'Открытая ячейка с вещами при переезде',
  ],
  sr: [
    'Otvoren boks sa kompletom sezonskih guma',
    'Otvoren boks sa naslaganim kartonskim kutijama',
    'Otvoren boks sa biciklom i skijama',
    'Otvoren boks sa stvarima pri selidbi',
  ],
  en: [
    'An open unit with a set of seasonal tires',
    'An open unit with stacked cardboard boxes',
    'An open unit with a bicycle and skis',
    'An open unit with belongings during a move',
  ],
}[lang];
---
<section class="section fits">
  <div class="container">
    <div class="section-head reveal">
      <span class="kicker">{t('fits.kicker')}</span>
      <h2>{t('fits.h2')}</h2>
    </div>

    <ul class="fits-grid">
      {items.map((item, i) => (
        <li class="fits-card card reveal" style={`transition-delay:${i * 70}ms`}>
          <div class="fits-media">
            <Image
              src={photos[i]}
              alt={alts[i]}
              widths={[260, 380, 520]}
              sizes="(min-width: 880px) 250px, (min-width: 560px) 45vw, 90vw"
              format="webp"
              quality={75}
              loading="lazy"
              class="fits-img"
            />
          </div>
          <div class="fits-body">
            <h3 class="fits-title">{item.title}</h3>
            <p class="fits-text">{item.text}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .fits-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .fits-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .fits-media {
    aspect-ratio: 4 / 5;
    background: #fff;
    overflow: hidden;
  }
  .fits-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* keep the open doorway + contents in frame, not just the white door */
    object-position: 38% 60%;
  }
  .fits-body {
    padding: 20px 20px 22px;
  }
  .fits-title {
    font-size: 1.05rem;
    margin-bottom: 11px;
  }
  .fits-text {
    color: var(--muted);
    font-size: 0.92rem;
  }

  @media (min-width: 560px) {
    .fits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 880px) {
    .fits-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .fits-media {
      aspect-ratio: 3 / 4;
    }
  }
</style>
