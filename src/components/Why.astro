---
import Icon from './Icon.astro';
import { useTranslations } from '../i18n/ui.js';

const { lang } = Astro.props;
const t = useTranslations(lang);
const all = t('why.items');

// The trust bar at the top already covers walkable / heated / monthly / language.
// Show only the points it does NOT, so nothing is duplicated and it reads as 4,
// not a wall of 8. Indices are stable across locales (same key order).
const PICK = [1, 4, 2, 7]; // gated site · flexible payment · your own key · flexible size
const iconByIndex = {
  1: 'fence',
  2: 'key',
  4: 'wallet',
  7: 'expand',
};
const items = PICK.map((i) => ({ ...all[i], icon: iconByIndex[i] }));
---
<section id="why" class="section why">
  <div class="container">
    <div class="section-head reveal">
      <span class="kicker">{t('why.kicker')}</span>
      <h2>{t('why.h2')}</h2>
    </div>

    <ul class="why-grid">
      {items.map((item, i) => (
        <li class="why-tile card reveal" style={`transition-delay:${i * 70}ms`}>
          <span class="why-icon"><Icon name={item.icon} size={22} /></span>
          <h3 class="why-title">{item.title}</h3>
          <p class="why-text">{item.text}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .why-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .why-tile {
    padding: 26px 24px;
  }
  .why-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: var(--green-soft);
    color: var(--green-dark);
    margin-bottom: 22px;
  }
  .why-title {
    font-size: 1.08rem;
    margin-bottom: 11px;
  }
  .why-text {
    color: var(--muted);
    font-size: 0.95rem;
  }

  @media (min-width: 560px) {
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 880px) {
    .why-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
