---
import { useTranslations } from '../i18n/ui.js';

const { lang } = Astro.props;
const t = useTranslations(lang);
const items = t('how.items');
const headings = { ru: 'Как это работает', sr: 'Kako funkcioniše', en: 'How it works' };
---
<section id="how" class="section how">
  <div class="container">
    <div class="section-head reveal">
      <h2>{headings[lang]}</h2>
    </div>

    <ol class="how-grid">
      {items.map((item, i) => (
        <li class="how-step reveal" style={`transition-delay:${i * 80}ms`}>
          <span class="how-num">{item.n}</span>
          <div class="how-body">
            <h3 class="how-title">{item.title}</h3>
            <p class="how-text">{item.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
  }
  .how-step {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .how-num {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--green);
    color: #fff;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.25rem;
    z-index: 1;
  }
  .how-title {
    font-size: 1.15rem;
    margin-bottom: 5px;
  }
  .how-text {
    color: var(--muted);
    max-width: 30ch;
  }

  @media (min-width: 760px) {
    .how-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .how-step {
      flex-direction: column;
    }
  }
</style>
