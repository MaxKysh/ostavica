---
/**
 * Inline line-icon set (Lucide-style, single stroke set, no dependency).
 * Usage: <Icon name="key" /> — inherits `currentColor`, sizes via `size`.
 */
const { name, size = 24, class: className = '' } = Astro.props;

const paths = {
  // trust bar
  walk: '<circle cx="13" cy="4" r="1"/><path d="m9 20 1-5 2-1-1-4-3 2-1 3"/><path d="m13 14 2 2 1 4"/><path d="m12 9 3 1 2-2"/>',
  shieldHeat:
    '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 9v6"/><path d="M9.5 11.5 12 9l2.5 2.5"/>',
  calendar:
    '<rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/>',
  globe:
    '<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18z"/>',
  // "what fits" 4th — moving / furniture
  sofa: '<path d="M5 9V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v3"/><path d="M3 11a2 2 0 0 1 2-2 2 2 0 0 1 2 2v2h10v-2a2 2 0 0 1 4 0v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M5 18v2M19 18v2"/>',
  // why tiles
  mapPin:
    '<path d="M20 10c0 5.5-8 12-8 12s-8-6.5-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>',
  fence:
    '<path d="M4 3v18M9 3v18M14 3v18M19 3v18M2 8h20M2 14h20"/>',
  key: '<circle cx="7.5" cy="15.5" r="4.5"/><path d="m10.5 12.5 8-8M15 7l3 3M18 4l3 3"/>',
  doorOpen:
    '<path d="M13 4h3a2 2 0 0 1 2 2v14"/><path d="M2 20h20"/><path d="M13 20V3.5a.5.5 0 0 0-.65-.48l-4 1.2A1 1 0 0 0 7 5.18V20"/><path d="M10 12v.01"/>',
  wallet:
    '<path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0 0 4h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5"/><circle cx="16.5" cy="12.5" r="1"/>',
  thermometer:
    '<path d="M14 4.5a2.5 2.5 0 0 0-5 0v9.26a4 4 0 1 0 5 0z"/><path d="M12 13v3"/>',
  message:
    '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/><path d="M8 12h.01M12 12h.01M16 12h.01"/>',
  expand:
    '<path d="M21 21H3V3"/><path d="M21 9V3h-6M3 15v6h6"/><path d="m21 3-7 7M3 21l7-7"/>',
  // ui
  menu: '<path d="M4 6h16M4 12h16M4 18h16"/>',
  close: '<path d="M18 6 6 18M6 6l12 12"/>',
  arrowRight: '<path d="M5 12h14M13 5l7 7-7 7"/>',
  chevronDown: '<path d="m6 9 6 6 6-6"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',
};

const body = paths[name] ?? '';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  focusable="false"
  set:html={body}
/>
