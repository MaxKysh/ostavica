---
import Brand from './Brand.astro';
import Icon from './Icon.astro';
import { languages, langLabels, localizedPath, useTranslations } from '../i18n/ui.js';

const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: '#sizes', label: t('nav.sizes') },
  { href: '#how', label: t('nav.how') },
  { href: '#reserve', label: t('nav.reserve') },
];
---
<header id="site-header" class="header">
  <div class="container header-inner">
    <div class="header-left">
      <a href={localizedPath(lang)} class="header-brand" aria-label="Ostavica — home">
        <Brand />
      </a>
      <span class="header-tagline">{t('footer.tagline')}</span>
    </div>

    <nav class="nav-center" aria-label="Primary">
      <ul class="nav-links">
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="nav-right">
      <div class="lang-switch" role="group" aria-label="Language">
        {languages.map((l) => (
          <a
            href={localizedPath(l)}
            data-lang-link
            data-base={localizedPath(l)}
            class:list={['lang-link', { active: l === lang }]}
            aria-current={l === lang ? 'true' : undefined}
            hreflang={l}
          >{langLabels[l]}</a>
        ))}
      </div>

      <a href="#reserve" class="btn btn-primary nav-cta">{t('nav.cta')}</a>
    </div>

    <button
      id="burger"
      class="burger"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="i-menu"><Icon name="menu" /></span>
      <span class="i-close"><Icon name="close" /></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" hidden>
    <ul class="mobile-links">
      {links.map((l) => (
        <li><a href={l.href} data-close-menu>{l.label}</a></li>
      ))}
    </ul>
    <a href="#reserve" data-close-menu class="btn btn-primary btn-block">{t('nav.cta')}</a>
    <div class="lang-switch mobile-lang" role="group" aria-label="Language">
      {languages.map((l) => (
        <a
          href={localizedPath(l)}
          data-lang-link
          data-base={localizedPath(l)}
          class:list={['lang-link', { active: l === lang }]}
          aria-current={l === lang ? 'true' : undefined}
          hreflang={l}
        >{langLabels[l]}</a>
      ))}
    </div>
  </div>
</header>

<style>
  .header {
    /* On mobile the header is not sticky — the logo scrolls away and the menu
       lives in a floating bottom-right button. Sticky kicks in on desktop. */
    position: relative;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    transition: background-color 0.25s ease;
  }
  @media (min-width: 880px) {
    .header {
      position: sticky;
      top: 0;
      backdrop-filter: saturate(140%) blur(12px);
      -webkit-backdrop-filter: saturate(140%) blur(12px);
    }
  }
  .header.is-scrolled {
    background: color-mix(in srgb, var(--bg) 96%, transparent);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    height: 64px;
  }
  .header-left {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }
  .header-brand {
    display: inline-flex;
    /* raise the logo so its bottom lines up with the menu/tagline text */
    transform: translateY(-7px);
  }
  .header-tagline {
    display: none;
    font-size: 0.82rem;
    color: var(--muted);
    white-space: nowrap;
  }
  @media (min-width: 1080px) {
    .header-tagline {
      display: inline;
    }
  }

  .nav-center,
  .nav-right {
    display: none;
  }
  .nav-links {
    display: flex;
    gap: clamp(14px, 2.2vw, 30px);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-links a {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink);
    padding: 6px 2px;
    transition: color 0.18s ease;
  }
  .nav-links a:hover {
    color: var(--green-dark);
  }

  /* Floating action button, bottom-right, thumb-friendly */
  .burger {
    position: fixed;
    right: 16px;
    bottom: max(16px, env(safe-area-inset-bottom, 0px));
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    border: 0;
    border-radius: 50%;
    background: var(--green);
    color: #fff;
    cursor: pointer;
  }
  .burger .i-menu,
  .burger .i-close {
    display: inline-flex;
  }
  .burger .i-close {
    display: none;
  }
  .burger[aria-expanded='true'] .i-menu {
    display: none;
  }
  .burger[aria-expanded='true'] .i-close {
    display: inline-flex;
  }

  /* Menu opens from the bottom-right, above the FAB */
  .mobile-menu {
    position: fixed;
    right: 16px;
    bottom: calc(max(16px, env(safe-area-inset-bottom, 0px)) + 66px);
    z-index: 59;
    width: min(76vw, 290px);
    background: var(--surface);
    border-radius: 18px;
    padding: 14px 16px 16px;
    box-shadow: 0 16px 42px rgba(20, 33, 23, 0.24);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transform-origin: bottom right;
    animation: menuIn 0.18s ease;
  }
  .mobile-menu[hidden] {
    display: none;
  }
  @keyframes menuIn {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .mobile-links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .mobile-links a {
    display: block;
    padding: 10px 4px;
    font-size: 1.05rem;
    font-weight: 500;
  }
  .mobile-lang {
    align-self: flex-start;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu {
      animation: none;
    }
  }

  @media (min-width: 880px) {
    /* logo left · menu centered · language + CTA right */
    .header-inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
    }
    .header-left {
      justify-self: start;
    }
    .nav-center {
      display: flex;
      justify-content: center;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: clamp(14px, 2.4vw, 28px);
      justify-self: end;
    }
    .burger,
    .mobile-menu {
      display: none !important;
    }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');
  if (burger && menu) {
    const setOpen = (open) => {
      menu.hidden = !open;
      burger.setAttribute('aria-expanded', String(open));
    };
    burger.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(menu.hidden);
    });
    menu.querySelectorAll('[data-close-menu]').forEach((el) =>
      el.addEventListener('click', () => setOpen(false))
    );
    // Close when tapping outside the menu/button
    document.addEventListener('click', (e) => {
      if (!menu.hidden && !menu.contains(e.target) && !burger.contains(e.target)) {
        setOpen(false);
      }
    });
    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.hidden) setOpen(false);
    });
  }
</script>
