---
import { Image } from 'astro:assets';
import { useTranslations } from '../i18n/ui.js';
import founder from '../images/person.jpg';

const { lang } = Astro.props;
const t = useTranslations(lang);

const founderAlt = {
  ru: 'Основатель Ostavica с ключами от ячеек',
  sr: 'Osnivač Ostavice sa ključevima od boksova',
  en: 'The founder of Ostavica holding the unit keys',
}[lang];
---
<section id="about" class="section about">
  <div class="container">
    <div class="about-card reveal">
      <div class="about-media">
        <Image
          src={founder}
          alt={founderAlt}
          widths={[280, 400, 560]}
          sizes="(min-width: 760px) 300px, 80vw"
          format="webp"
          quality={75}
          loading="lazy"
          class="about-img"
        />
      </div>

      <div class="about-copy">
        <span class="kicker">{t('about.kicker')}</span>
        <h2>{t('about.h2')}</h2>
        <p class="about-text">{t('about.text')}</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Self-contained "founder" card so the block matches the page's card
     language and doesn't leave a big empty column on the right. */
  .about-card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: clamp(20px, 3.5vw, 40px);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(22px, 4vw, 48px);
    align-items: center;
  }
  .about-media {
    max-width: 320px;
  }
  .about-img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius);
  }
  .about-copy h2 {
    font-size: clamp(1.6rem, 3.4vw, 2.2rem);
    margin-bottom: 18px;
  }
  .about-text {
    color: var(--muted);
    font-size: clamp(1.05rem, 1.5vw, 1.18rem);
    line-height: 1.65;
  }

  @media (min-width: 820px) {
    /* full content width, photo left, text fills the whole right column */
    .about-card {
      grid-template-columns: minmax(320px, 420px) 1fr;
    }
    .about-media {
      max-width: none;
    }
  }
</style>
