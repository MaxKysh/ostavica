---
import { useTranslations } from '../i18n/ui.js';

const { lang } = Astro.props;
const t = useTranslations(lang);
const privacyHref = `/privacy-${lang}.pdf`;
---
<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Cookies" hidden>
  <p class="cookie-text">
    {t('cookies.text')}{' '}
    <a href={privacyHref} target="_blank" rel="noopener">{t('cookies.more')}</a>
  </p>
  <div class="cookie-actions">
    <button type="button" class="cookie-btn cookie-accept" data-consent="accept">{t('cookies.accept')}</button>
  </div>
</div>

<style>
  /* Bottom card. On mobile it sits above the floating menu button so they
     don't overlap; on desktop it's pinned near the bottom. */
  .cookie-banner {
    position: fixed;
    z-index: 80;
    left: 16px;
    right: 16px;
    bottom: calc(max(16px, env(safe-area-inset-bottom, 0px)) + 62px);
    max-width: 620px;
    margin-inline: auto;
    background: var(--green-deep);
    color: #fff;
    border-radius: 16px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .cookie-text {
    font-size: 0.9rem;
    line-height: 1.5;
    color: #e6f0dc;
  }
  .cookie-text a {
    color: #fff;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cookie-actions {
    display: flex;
    justify-content: flex-end;
  }
  .cookie-btn {
    border: 0;
    border-radius: 999px;
    padding: 10px 22px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    touch-action: manipulation;
    transition: background-color 0.18s ease, color 0.18s ease;
  }
  .cookie-accept {
    background: #fff;
    color: var(--green-dark);
  }
  .cookie-accept:hover {
    background: #eef6e4;
  }

  @media (min-width: 560px) {
    .cookie-banner {
      flex-direction: row;
      align-items: center;
      gap: 20px;
    }
    .cookie-text {
      flex: 1;
    }
    .cookie-actions {
      flex: none;
    }
  }
  /* No floating menu button on desktop — sit at the very bottom. */
  @media (min-width: 880px) {
    .cookie-banner {
      bottom: max(16px, env(safe-area-inset-bottom, 0px));
    }
  }
</style>
